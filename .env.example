# Copie este arquivo para .env e preencha.

# Last.fm — crie uma API key em https://www.last.fm/api/account/create
# IMPORTANTE: SEM prefixo VITE_. Esta chave é lida só no servidor (pela função
# api/lastfm.ts) e NUNCA vai para o bundle do navegador. No Vercel, cadastre-a
# em Project Settings → Environment Variables como LASTFM_API_KEY.
LASTFM_API_KEY=

# Spotify — crie um app em https://developer.spotify.com/dashboard e cadastre
# a Redirect URI (a URL onde o site roda, ex.: http://localhost:5173/).
# Só o Client ID é necessário (o fluxo é PKCE, sem client secret). O Client ID
# é público por design — pode aparecer no bundle sem problema (por isso VITE_).
VITE_SPOTIFY_CLIENT_ID=
